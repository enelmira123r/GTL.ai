# Kopjoje këtë skedar si ".env" dhe vendos çelësin tënd të vërtetë.
# Çelësin FALAS e merr te: https://aistudio.google.com  ("Get API key")

GEMINI_API_KEY=

# Modeli (opsional). Parazgjedhja: gemini-2.5-flash (i shpejtë dhe falas).
# Alternativa: gemini-flash-lite-latest
GEMINI_MODEL=gemini-2.5-flash

# Porta e serverit (opsional)
PORT=3001

# (Opsionale) Sekret për nënshkrimin e token-eve të login-it. Nëse s'e vendos,
# krijohet vetvetiu te skedari .authsecret.
# AUTH_SECRET=

# (Opsionale) Folderi ku ruhen automatikisht TË GJITHA provimet e gjeneruara
# (nga çdo përdorues), në PC-në ku punon serveri. Parazgjedhja: ./provimet
# Mund të vendosësh rrugë absolute, p.sh.:  SAVE_DIR=C:\Users\Enel\Desktop\Provimet
# SAVE_DIR=
